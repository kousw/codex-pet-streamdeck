{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-pet-streamdeck.local/schemas/frame-status.schema.json",
  "title": "Codex Pet Frame Status",
  "type": "object",
  "required": ["version", "status", "updatedAt"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "codex-not-running",
        "window-not-found",
        "screen-recording-denied",
        "capture-failed",
        "stale-frame",
        "helper-not-running"
      ]
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "framePath": {
      "type": "string"
    },
    "frameSequence": {
      "type": "integer",
      "minimum": 0
    },
    "frameSlot": {
      "type": "integer",
      "minimum": 0
    },
    "frameDataPath": {
      "type": "string"
    },
    "captureMode": {
      "type": "string",
      "enum": ["pet", "pet-with-bubble", "debug-wide"]
    },
    "captureFPS": {
      "type": "number",
      "minimum": 1,
      "maximum": 15
    },
    "crop": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "number",
          "minimum": 0
        },
        "y": {
          "type": "number",
          "minimum": 0
        },
        "width": {
          "type": "number",
          "minimum": 8
        },
        "height": {
          "type": "number",
          "minimum": 8
        }
      },
      "additionalProperties": false
    },
    "targetWindowID": {
      "type": "integer",
      "minimum": 0
    },
    "message": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
